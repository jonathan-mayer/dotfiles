export main_dir="${main_dir/#\~/$HOME}"
# create basename variables for dirs
export dev_dir_name="$(basename -- "$dev_dir")" 
export main_dir_name="$(basename -- "$main_dir")" 

# dev path roots helper
_dev_path() {
  local p="$1"
  local resolved=""
  if [[ "$p" == "chezmoi" ]]; then
    resolved="$(chezmoi source-path)"
  elif [[ "$p" != - && "$p" != /* && "$p" != ./* && "$p" != . && "$p" != ../* && "$p" != .. ]]; then
    if [[ "$p" == "$main_dir_name" ]]; then
      resolved="$main_dir"
    elif [[ "$p" == "$main_dir_name"/* ]]; then
      resolved="$main_dir/${p#"$main_dir_name"/}"
    elif [[ "$p" == dev/* ]]; then
      resolved="$dev_dir/${p#dev/}"
    elif [[ "$p" == "$dev_dir_name"/* ]]; then
      resolved="$dev_dir/${p#"$dev_dir_name"/}"
    elif [[ "$p" == dev || "$p" == "$dev_dir_name" ]]; then
      resolved="$dev_dir"
    else
      resolved="$main_dir/$p"
    fi
  else
    resolved="$p"
  fi

  if [[ -e "$resolved" ]]; then
    printf '%s\n' "$resolved"
  else
    printf '%s\n' "$p"
  fi
}
_dev_path_completion() {
  local cur
  cur="${COMP_WORDS[COMP_CWORD]}"

  [[ "$cur" == -* ]] && return 0

  COMPREPLY=()
  compopt -o filenames -o nospace 2>/dev/null

  local IFS=$'\n'
  local -a pwd_matches
  pwd_matches=($(compgen -f -- "$cur"))

  _add_unique() {
    local item
    for item in "$@"; do
      [[ " ${COMPREPLY[*]} " == *" $item "* ]] || COMPREPLY+=("$item")
    done
  }

  _add_unique "${pwd_matches[@]}"

  # Offer virtual root tokens at top level
  if [[ -z "$cur" || ( "$cur" != /* && "$cur" != ./* && "$cur" != ../* && "$cur" != */* ) ]]; then
    local -a vwords=("chezmoi" "dev/" "${dev_dir_name}/" "${main_dir_name}/" "~" "." "..")
    _add_unique $(compgen -W "${vwords[*]}" -- "$cur")
  fi

  _dev_path_completion_under() {
    local base="$1" vprefix="$2" rest="$3"
    local m out real

    for m in $(compgen -f -- "$base/$rest"); do
      real="$m"

      out="${m#$base/}"
      out="${out#$base}"

      [[ -d "$real" ]] && out="${out}/"

      if [[ -n "$vprefix" ]]; then
        _add_unique "$vprefix/$out"
      else
        _add_unique "$out"
      fi
    done
  }

  if [[ "$cur" == chezmoi* ]]; then
    _add_unique $(compgen -W "chezmoi" -- "$cur")
  fi

  case "$cur" in
    dev/*)
      _dev_path_completion_under "$dev_dir" "dev" "${cur#dev/}"
      ;;
    "${dev_dir_name}"/*)
      _dev_path_completion_under "$dev_dir" "$dev_dir_name" "${cur#"$dev_dir_name"/}"
      ;;
    "${main_dir_name}"/*)
      _dev_path_completion_under "$main_dir" "$main_dir_name" "${cur#"$main_dir_name"/}"
      ;;
    *)
      _dev_path_completion_under "$main_dir" "" "$cur"
      ;;
  esac

  return 0
}

# vscode cli wrapper alias
code() {
  resolve_workspace_path() {
  local input_path="$1"

    # If it's not a directory, return as-is
    if [[ ! -d "$input_path" ]]; then
      printf '%s\n' "$input_path"
      return 0
    fi

    # Find *.code-workspace files directly inside the directory
    local workspace_files=()
    while IFS= read -r -d '' file; do
      workspace_files+=("$file")
    done < <(find "$input_path" -maxdepth 1 -type f -name '*.code-workspace' -print0)

    # If exactly one workspace file exists, return it
    if [[ "${#workspace_files[@]}" -eq 1 ]]; then
      printf '%s\n' "${workspace_files[0]}"
    else
      printf '%s\n' "$input_path"
    fi
  }

  local -a flags=()
  local -a paths=()

  for arg in "$@"; do
    if [[ "$arg" == -* ]]; then
      flags+=("$arg")
    else
      paths+=("$(resolve_workspace_path "$(_dev_path "$arg")")")
    fi
  done

  if [[ ${#paths[@]} -eq 0 ]]; then
    command code "${flags[@]}"
    return
  fi

  # open all paths in one window on -r/--reuse-window
  local f
  for f in "${flags[@]}"; do
    if [[ "$f" == "-r" || "$f" == "--reuse-window" || "$f" == "-n" || "$f" == "--new-window" ]]; then
      command code "${flags[@]}" "${paths[@]}"
      return $?
    fi
  done

  # open every path in separate windows
  local rc=0
  local p
  for p in "${paths[@]}"; do
    command code "${flags[@]}" "$p" || rc=$?
  done

  return $rc
}
complete -F _dev_path_completion code

