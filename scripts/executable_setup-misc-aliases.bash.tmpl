# list repo aliases in $dev_dir
dev-list-aliases() {
  find $dev_dir -type l -exec sh -c '
  for link; do
    target=$(readlink -f "$link") || continue
    [ -d "$target" ] || continue

    if [ -d "$target/.git" ]; then
      printf "%s -> %s\n" "$link" "$target"
      continue
    fi

    for d in "$target"/*; do
      [ -d "$d/.git" ] && {
        printf "%s -> %s\n" "$link" "$target"
        break
      }
    done
  done
  ' sh {} +
}

