#! /bin/bash

# Update Function
_UPDATE_TIMESTAMP_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/last-update"

update() {
  if [ -f "$_UPDATE_TIMESTAMP_FILE" ]; then
    echo "Last update: $(cat "$_UPDATE_TIMESTAMP_FILE")"
  else
    echo "Last update: never"
  fi
  echo ""

{{- if eq .chezmoi.osRelease.id "arch" }}
  sudo pacman -Syu --noconfirm && yay -Syu --rebuildall --noconfirm && brew upgrade && flatpak update -y
{{- else if eq .chezmoi.osRelease.id "fedora" }}
  sudo dnf upgrade --refresh -y && brew upgrade && flatpak update -y
{{- else }}
  sudo apt update && sudo apt upgrade -y && brew upgrade
{{- end }}

  if [ $? -eq 0 ]; then
    mkdir -p "$(dirname "$_UPDATE_TIMESTAMP_FILE")"
    date "+%Y-%m-%d %H:%M:%S" > "$_UPDATE_TIMESTAMP_FILE"
  fi
}

# Pre-Commit Aliases
alias pci="pre-commit install" \
    pcu="pre-commit uninstall" \
    pc="pre-commit" \
    pcr="pre-commit run --all-files"

# Lines Changed Aliases
alias lines-changed="git diff --stat main --cached -- . ':(exclude)**/package-lock.json'"
alias lines-staged="git diff --stat HEAD --cached -- . ':(exclude)**/package-lock.json'"
alias lines-total="git ls-files --others --exclude-standard --cached -z | grep -zv 'package\.json\|package-lock\.json' | xargs -0 wc -l"
alias lines-total-go="find . -name '*' -type f | grep -e '\.go$' | grep -ve '_test\.go$' | xargs wc -l"

# Dotenv Alias
dotenv() {
    local env_file="${1:-.env}"
    if [[ -f "$env_file" ]]; then
        export $(grep -v ^# "$env_file" | xargs)
    else
        echo "File $env_file not found!"
    fi
}

# Kubernetes Context Alias
export default_ctx={{ .default_ctx | quote }}

_ctx_state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/ctx"
_ctx_base_file="$_ctx_state_dir/base"
_ctx_current_file="$_ctx_state_dir/current"

if [ -f "$_ctx_base_file" ]; then
    _ctx_base_kubeconfig="$(cat "$_ctx_base_file")"
else
    _ctx_base_kubeconfig="${KUBECONFIG:-$HOME/.kube/config}"
    case "$_ctx_base_kubeconfig" in
        *:*) _ctx_base_kubeconfig="$HOME/.kube/config" ;;
    esac
    mkdir -p "$_ctx_state_dir"
    printf '%s\n' "$_ctx_base_kubeconfig" > "$_ctx_base_file"
fi

if [ -f "$_ctx_current_file" ]; then
    export KUBECONFIG="$(cat "$_ctx_current_file")"
fi

: "${_ctx_local:=0}"

_ctx_save() {
    [ "$_ctx_local" = 1 ] && return 0
    mkdir -p "$_ctx_state_dir"
    printf '%s\n' "$KUBECONFIG" > "$_ctx_current_file"
}

_ctx_localize() {
    [ "$_ctx_local" = 1 ] && return 0
    _ctx_tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/ctx.XXXXXX")" || return 1
    cp "$_ctx_base_kubeconfig" "$_ctx_tmpdir/base" 2>/dev/null
    _ctx_base_kubeconfig="$_ctx_tmpdir/base"
    _ctx_local=1
    export KUBECONFIG="$_ctx_base_kubeconfig"
    trap '[ -n "$_ctx_tmpdir" ] && rm -rf "$_ctx_tmpdir"' EXIT
}

_ctx_kubeconfig_globs=(
{{- if and (hasKey . "k8s") (hasKey .k8s "clusters") (gt (len .k8s.clusters) 0) }}
  "$HOME/.kube/managed/*/kubeconfig"
{{- end }}
{{- if and (hasKey . "k8s") (hasKey .k8s "kubeconfigs") }}
{{- range .k8s.kubeconfigs }}
  {{ . | quote }}
{{- end }}
{{- end }}
)

_ctx_kubeconfigs() {
    local pattern path matches
    for pattern in "${_ctx_kubeconfig_globs[@]}"; do
        [[ -n "$pattern" ]] || continue
        eval "matches=( $pattern )"
        for path in "${matches[@]}"; do
            [[ -f "$path" ]] || continue
            printf '%s\t%s\n' "$(basename "$(dirname "$path")")" "$path"
        done
    done
}

_ctx_resolve_kubeconfig() {
    local name="$1" kc_name kc_path
    while IFS=$'\t' read -r kc_name kc_path; do
        if [[ "$kc_name" == "$name" ]]; then
            printf '%s\n' "$kc_path"
            return 0
        fi
    done < <(_ctx_kubeconfigs)
    return 1
}

# Selectable names: base contexts plus glob kubeconfig names.
_ctx_names() {
    echo "none $(KUBECONFIG="$_ctx_base_kubeconfig" kubectl config get-contexts -o name 2>/dev/null) $(_ctx_kubeconfigs | cut -f1)"
}

# Point KUBECONFIG at the base config only.
_ctx_use_base() {
    export KUBECONFIG="$_ctx_base_kubeconfig"
}

# Switch to a target: either a glob-managed kubeconfig or a base context.
_ctx_switch() {
    local name="$1" kubeconfig target
    if ! kubeconfig="$(_ctx_resolve_kubeconfig "$name")"; then
        _ctx_use_base
        kubectl config use-context "$name"
        return
    fi

    # In local mode, operate on a private copy so the real file is untouched.
    if [ "$_ctx_local" = 1 ]; then
        local copy="$_ctx_tmpdir/$(basename "$(dirname "$kubeconfig")")"
        cp "$kubeconfig" "$copy" && kubeconfig="$copy"
    fi

    # Merge glob file first so its current-context wins while base stays visible.
    export KUBECONFIG="$kubeconfig:$_ctx_base_kubeconfig"
    target="$(KUBECONFIG="$kubeconfig" kubectl config current-context 2>/dev/null)"
    [ -z "$target" ] && target="$(KUBECONFIG="$kubeconfig" kubectl config get-contexts -o name 2>/dev/null | head -n1)"
    [ -n "$target" ] && kubectl config use-context "$target" >/dev/null
    echo "KUBECONFIG=$KUBECONFIG"
    kubectl config current-context 2>/dev/null
}

ctx() {
    if [ "$1" == "-l" ] || [ "$1" == "--local" ]; then
        _ctx_localize || return 1
        shift
        if [ $# -eq 0 ]; then
            echo "KUBECONFIG=$KUBECONFIG (local)"
            kubectl config current-context 2>/dev/null
            return 0
        fi
    fi

    if [ $# -eq 0 ]; then
        kubectl config current-context 2>/dev/null
        KUBECONFIG="$_ctx_base_kubeconfig" kubectl config get-contexts
        _ctx_kubeconfigs | cut -f1
        return 0
    fi

    case "$1" in
        ""|none) _ctx_use_base; kubectl config unset current-context ;;
        -)       _ctx_use_base; kubectl config use-context "$default_ctx" ;;
        *)       _ctx_switch "$1" ;;
    esac
    _ctx_save
}

_ctx() {
    local names
    names="$(_ctx_names)"
    if [[ $COMP_CWORD -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "-l --local $names" -- "${COMP_WORDS[1]}") )
    elif [[ $COMP_CWORD -eq 2 && ( "${COMP_WORDS[1]}" == "-l" || "${COMP_WORDS[1]}" == "--local" ) ]]; then
        COMPREPLY=( $(compgen -W "$names" -- "${COMP_WORDS[2]}") )
    fi
}
complete -F _ctx ctx

inctx() {
  local target_ctx="$1"
  shift

  if [[ -z "$target_ctx" ]]; then
    echo "usage: inctx <ctx> <command...>" >&2
    return 2
  fi

  ctx "$target_ctx" || return 1

  "$@"
  local status=$?

  ctx - || return 1

  return $status
}
_inctx() {
  if [[ $COMP_CWORD -eq 1 ]]; then
    COMPREPLY=(
      $(compgen -W "$(_ctx_names)" -- "${COMP_WORDS[1]}")
    )
    return 0
  fi

  compopt -o default -o bashdefault 2>/dev/null
  COMPREPLY=()
  return 0
}
complete -F _inctx inctx

incd() {
  local target_dir="$1"
  local target_dir="$(_dev_path "$1")"
  shift

  if [[ -z "$target_dir" ]]; then
    echo "usage: incd <dir> <command...>" >&2
    return 2
  fi

  pushd "$target_dir" >/dev/null || return 1

  "$@"
  local status=$?

  # Return to previous dir
  popd >/dev/null || return 1

  return $status
}
_incd() {
  if [[ $COMP_CWORD -eq 1 ]]; then
    _dev_path_completion
    return 0
  fi

  compopt -o default -o bashdefault 2>/dev/null
  COMPREPLY=()
  return 0
}
complete -F _incd incd


