#! /bin/bash
set -eu

managed_dir="$HOME/.kube/managed"

{{- if and (hasKey . "k8s") (hasKey .k8s "clusters") (gt (len .k8s.clusters) 0) }}

mkdir -p "$managed_dir"

# Names of clusters currently declared in chezmoi config.
keep=(
{{- range .k8s.clusters }}
  {{ .name | quote }}
{{- end }}
)

# Prune managed clusters that are no longer declared.
if [ -d "$managed_dir" ]; then
    for dir in "$managed_dir"/*/; do
        [ -d "$dir" ] || continue
        name="$(basename "$dir")"
        found=0
        for k in "${keep[@]}"; do
            [ "$k" = "$name" ] && { found=1; break; }
        done
        [ "$found" -eq 0 ] && rm -rf "$dir"
    done
fi

{{- range .k8s.clusters }}

mkdir -p "$managed_dir/{{ .name }}"
cat > "$managed_dir/{{ .name }}/kubeconfig" <<'KUBECONFIG_EOF'
apiVersion: v1
kind: Config
clusters:
- name: {{ .name }}
  cluster:
    server: {{ .url }}
{{- if .insecure }}
    insecure-skip-tls-verify: true
{{- end }}
contexts:
- name: {{ .name }}
  context:
    cluster: {{ .name }}
    user: {{ .name }}
current-context: {{ .name }}
users:
- name: {{ .name }}
{{- if eq .user_type "oidc" }}
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      command: kubectl
      args:
      - oidc-login
      - get-token
      - --oidc-issuer-url={{ .oidc_issuer_url }}
      - --oidc-client-id={{ .oidc_client_id }}
      - --oidc-extra-scope={{ .oidc_extra_scope }}
{{- else }}
  user: {}
{{- end }}
KUBECONFIG_EOF
chmod 600 "$managed_dir/{{ .name }}/kubeconfig"
{{- end }}

{{- else }}

# No managed clusters declared; remove generated directory if present.
[ -d "$managed_dir" ] && rm -rf "$managed_dir"
true

{{- end }}
